<?xml version="1.0"?>
<ruleset name="API Gateway">
    <description>PHP CodeSniffer rules for API Gateway</description>

    <!-- Scan these paths -->
    <file>app</file>
    <file>tests</file>

    <!-- Exclude vendor and generated files -->
    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>bootstrap/cache/*</exclude-pattern>
    <exclude-pattern>storage/*</exclude-pattern>

    <!-- Use PSR-12 standard -->
    <rule ref="PSR12">
        <!-- Allow snake_case method names in tests (PHPUnit convention) -->
        <exclude name="PSR1.Methods.CamelCapsMethodName"/>

        <!-- Pint uses no spaces around . operator: 'str'.$var -->
        <!-- PSR-12 wants: 'str' . $var -->
        <exclude name="PSR12.Operators.OperatorSpacing"/>

        <!-- Pint omits parentheses on no-arg instantiation: new JWTService -->
        <!-- PSR-12 wants: new JWTService() -->
        <exclude name="PSR12.Classes.ClassInstantiation.MissingParentheses"/>
    </rule>

    <!-- Pint puts empty constructor body on same line: __construct() {} -->
    <!-- PHPCS wants closing brace on its own line -->
    <rule ref="Squiz.WhiteSpace.ScopeClosingBrace">
        <exclude name="Squiz.WhiteSpace.ScopeClosingBrace.ContentBefore"/>
    </rule>

    <!-- Show progress -->
    <arg value="p"/>
    <arg name="colors"/>
</ruleset>
